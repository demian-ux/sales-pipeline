# Oaki — env template
# Copy this file to .env.local and fill in real values for local development.
# In production (Vercel), set these in the Vercel project's Environment Variables.

# === Anthropic ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_MS=90000

# === Google Sheets (service account) ===
GOOGLE_SHEET_ID=
GOOGLE_CLIENT_EMAIL=
# Paste the multiline RSA private key as-is. Local .env files: wrap in quotes and use literal \n
# for newlines. On Vercel: paste the raw multiline value into the env UI (handles newlines correctly).
GOOGLE_PRIVATE_KEY=

# === Google OAuth (Gmail integration) ===
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Local: http://localhost:3000/api/gmail/callback
# Vercel: https://<your-domain>/api/gmail/callback (must match the URI added in Google Cloud Console)
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# === Supabase (machine-data store: Discoveries, RawArticles, IngestionRuns, Threads, app_secrets) ===
# Filled in once the Supabase project is provisioned. Anon key is browser-safe; service role is server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Discoveries ingestion ===
# Strong random string. Required as `Authorization: Bearer <secret>` on POST /api/discoveries/ingest.
INGEST_SECRET=
# Strong random string (min 16 chars). When set in Vercel, cron invocations carry
# `Authorization: Bearer <CRON_SECRET>` automatically and the bare x-vercel-cron
# header is no longer trusted (it is client-spoofable). SET THIS IN PRODUCTION.
CRON_SECRET=

# === AI model tiers ===
# Optional cheaper model for the yes/no article triage step (the deep analysis
# still uses ANTHROPIC_MODEL). Recommended: claude-haiku-4-5
ANTHROPIC_CLASSIFIER_MODEL=

# === Prospecting (Tavily + Jina Reader) ===
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS_PER_QUERY=8
TAVILY_TIMEOUT_MS=20000
JINA_READER_BASE_URL=https://r.jina.ai
JINA_TIMEOUT_MS=25000
ARTICLE_MAX_CHARS=20000

# === App auth (single user) ===
# Login password for the basic-auth login page.
APP_PASSWORD=
# Random secret used to sign the session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET=
